MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# One topic per database (topic-based routing, each carries different data)
MQTT_TOPIC_NETWORK=environmental/network
MQTT_TOPIC_READINGS=environmental/readings
MQTT_TOPIC_TELEMETRY=environmental/telemetry

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3308
MYSQL_USER=envuser
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=env_monitoring

MONGODB_URI=mongodb://root:your_mongo_password@localhost:27018/
MONGODB_DB=env_monitoring
MONGODB_COLLECTION=sensor_messages

NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
